<script>
(function () {
  var PLACEHOLDER = 'apps.cluster.example.com';
  var ATTR_CLUSTER = '{cluster_domain}';
  var ATTR_USER = '{user_name}';
  function resolveClusterDomain() {
    try {
      var q = new URLSearchParams(window.location.search || '').get('CLUSTER_DOMAIN');
      if (q && q.indexOf('apps.') === 0) return q;
    } catch (e) {}
    var h = location.hostname || '';
    var m = /^showroom-showroom\.(apps\..+)$/i.exec(h);
    return m ? m[1] : '';
  }
  function resolveUserName() {
    try {
      var u = new URLSearchParams(window.location.search || '').get('USER_NAME');
      if (u) return decodeURIComponent(u);
    } catch (e) {}
    return '';
  }
  /** Fallback if HTML still has relative _images/… (older builds). Playbook now sets imagesdir: /modules/_images for root-relative SVG URLs. */
  function moduleStaticBaseDir() {
    var path = location.pathname || '/';
    var dir = path.endsWith('/') ? path : path.replace(/[^/]+$/, '');
    if (dir.indexOf('/modules') !== -1) return dir.replace(/\/?$/, '/');
    return '/modules/';
  }
  function fixModuleImages() {
    if (!document.body) return;
    var baseDir = moduleStaticBaseDir();
    document.querySelectorAll('img[src^="_images/"], img[src^="./_images/"]').forEach(function (img) {
      var s = img.getAttribute('src');
      if (!s || s.indexOf('://') !== -1) return;
      var rel = s.replace(/^\.\//, '');
      img.src = location.origin + baseDir + rel;
    });
  }
  function rewriteAttrs(s, domain, userName) {
    if (!s) return s;
    var out = s;
    if (domain && out.indexOf(ATTR_CLUSTER) !== -1)
      out = out.split(ATTR_CLUSTER).join(domain);
    if (userName && out.indexOf(ATTR_USER) !== -1)
      out = out.split(ATTR_USER).join(userName);
    if (domain && out.indexOf(PLACEHOLDER) !== -1 && domain !== PLACEHOLDER)
      out = out.split(PLACEHOLDER).join(domain);
    return out;
  }
  function apply() {
    if (!document.body) return;
    fixModuleImages();
    var domain = resolveClusterDomain();
    var userName = resolveUserName();
    if (!domain && !userName) return;
    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    var textNodes = [];
    var node;
    while ((node = walker.nextNode())) textNodes.push(node);
    textNodes.forEach(function (n) {
      var v = n.nodeValue;
      var next = rewriteAttrs(v, domain, userName);
      if (next !== v) n.nodeValue = next;
    });
    document.querySelectorAll('a[href]').forEach(function (a) {
      var h = a.getAttribute('href');
      if (!h || (h.indexOf(ATTR_CLUSTER) < 0 && h.indexOf(ATTR_USER) < 0 && h.indexOf(PLACEHOLDER) < 0))
        return;
      var nh = rewriteAttrs(h, domain, userName);
      if (nh !== h) a.setAttribute('href', nh);
    });
    document.querySelectorAll('iframe[src]').forEach(function (f) {
      var s = f.getAttribute('src');
      if (!s || (s.indexOf(ATTR_CLUSTER) < 0 && s.indexOf(ATTR_USER) < 0 && s.indexOf(PLACEHOLDER) < 0))
        return;
      var ns = rewriteAttrs(s, domain, userName);
      if (ns !== s) f.setAttribute('src', ns);
    });
    document.querySelectorAll('img[src]').forEach(function (img) {
      var s = img.getAttribute('src');
      if (!s || (s.indexOf(ATTR_CLUSTER) < 0 && s.indexOf(ATTR_USER) < 0 && s.indexOf(PLACEHOLDER) < 0))
        return;
      var ns = rewriteAttrs(s, domain, userName);
      if (ns !== s) img.setAttribute('src', ns);
    });
  }
  function kick() {
    apply();
  }
  function init() {
    kick();
    window.addEventListener('load', kick);
    var n = 0;
    var timer = setInterval(function () {
      kick();
      if (++n >= 30) clearInterval(timer);
    }, 400);
    var debounce;
    function schedule() {
      clearTimeout(debounce);
      debounce = setTimeout(kick, 100);
    }
    if (document.body) {
      try {
        new MutationObserver(schedule).observe(document.body, {
          subtree: true,
          childList: true,
          attributes: true,
          attributeFilter: ['src', 'href']
        });
      } catch (e) {}
    }
  }
  if (document.readyState === 'loading')
    document.addEventListener('DOMContentLoaded', init);
  else
    init();
})();
</script>
