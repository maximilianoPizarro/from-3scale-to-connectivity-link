{
  "openapi": "3.0.3",
  "info": {
    "title": "Wire Transfer API",
    "version": "1.0",
    "description": "Domestic and international wire transfers, SWIFT messaging, and transfer status tracking"
  },
  "paths": {
    "/api/v1/transfers": {
      "post": {
        "operationId": "createTransfer",
        "summary": "Initiate a wire transfer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transfer"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "TRF-10001",
                      "type": "domestic",
                      "amount": 5000.0,
                      "currency": "USD",
                      "fromAccount": "ACC-001",
                      "toAccount": "ACC-099",
                      "status": "processing",
                      "createdAt": "2024-12-01T14:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transfers/{id}": {
      "get": {
        "operationId": "getTransfer",
        "summary": "Get transfer details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transfer"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "TRF-10001",
                      "type": "domestic",
                      "amount": 5000.0,
                      "currency": "USD",
                      "fromAccount": "ACC-001",
                      "toAccount": "ACC-099",
                      "status": "completed",
                      "createdAt": "2024-12-01T14:00:00Z",
                      "completedAt": "2024-12-01T14:05:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transfers/{id}/status": {
      "get": {
        "operationId": "getTransferStatus",
        "summary": "Get transfer status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "transferId": "TRF-10001",
                      "status": "completed",
                      "steps": [
                        {
                          "name": "validation",
                          "status": "done"
                        },
                        {
                          "name": "compliance",
                          "status": "done"
                        },
                        {
                          "name": "execution",
                          "status": "done"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transfers/swift": {
      "post": {
        "operationId": "createSwiftTransfer",
        "summary": "Initiate a SWIFT international transfer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SwiftRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "id": "SWF-5001",
                      "swiftCode": "BSCHESMMXXX",
                      "amount": 25000.0,
                      "currency": "EUR",
                      "beneficiary": "European Corp Ltd",
                      "status": "pending_compliance",
                      "estimatedArrival": "2024-12-04T10:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Transfer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "fromAccount": {
            "type": "string"
          },
          "toAccount": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransferRequest": {
        "type": "object",
        "properties": {
          "fromAccount": {
            "type": "string"
          },
          "toAccount": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "SwiftRequest": {
        "type": "object",
        "properties": {
          "fromAccount": {
            "type": "string"
          },
          "swiftCode": {
            "type": "string"
          },
          "beneficiary": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      }
    }
  }
}
