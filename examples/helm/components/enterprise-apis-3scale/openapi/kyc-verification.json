{
  "openapi": "3.0.3",
  "info": {
    "title": "KYC Verification API",
    "version": "1.0",
    "description": "Identity verification, document upload, AML screening, and compliance checks"
  },
  "paths": {
    "/api/v1/kyc/verify": {
      "post": {
        "operationId": "startVerification",
        "summary": "Start KYC verification process",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerificationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Verification"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "KYC-3001",
                      "customerId": "CUST-001",
                      "status": "pending_documents",
                      "riskLevel": "medium",
                      "createdAt": "2024-12-01T09:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/kyc/documents": {
      "post": {
        "operationId": "uploadDocument",
        "summary": "Upload verification document",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentUpload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "id": "DOC-4001",
                      "kycId": "KYC-3001",
                      "type": "passport",
                      "status": "uploaded",
                      "uploadedAt": "2024-12-01T09:15:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/kyc/{id}/status": {
      "get": {
        "operationId": "getKycStatus",
        "summary": "Get KYC verification status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "kycId": "KYC-3001",
                      "status": "verified",
                      "checks": [
                        {
                          "name": "identity",
                          "result": "pass"
                        },
                        {
                          "name": "aml_screening",
                          "result": "pass"
                        },
                        {
                          "name": "sanctions",
                          "result": "clear"
                        }
                      ],
                      "completedAt": "2024-12-01T10:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/kyc/{id}/report": {
      "get": {
        "operationId": "getKycReport",
        "summary": "Get full KYC compliance report",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "kycId": "KYC-3001",
                      "customerId": "CUST-001",
                      "riskScore": 25,
                      "riskLevel": "low",
                      "verificationResult": "approved",
                      "amlScreening": {
                        "result": "clear",
                        "databases": [
                          "OFAC",
                          "EU-Sanctions",
                          "UN-Sanctions"
                        ]
                      },
                      "documents": [
                        {
                          "type": "passport",
                          "verified": true
                        },
                        {
                          "type": "proof_of_address",
                          "verified": true
                        }
                      ],
                      "reportGeneratedAt": "2024-12-01T10:30:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Verification": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "customerId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_documents",
              "in_review",
              "verified",
              "rejected"
            ]
          },
          "riskLevel": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      },
      "VerificationRequest": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "nationality": {
            "type": "string"
          }
        }
      },
      "DocumentUpload": {
        "type": "object",
        "properties": {
          "kycId": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "passport",
              "drivers_license",
              "national_id",
              "proof_of_address"
            ]
          },
          "contentBase64": {
            "type": "string"
          }
        }
      }
    }
  }
}
