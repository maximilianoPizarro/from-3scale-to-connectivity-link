{
  "openapi": "3.0.3",
  "info": {
    "title": "Card Issuing API",
    "version": "1.0",
    "description": "Card provisioning, activation, limit management, and virtual card generation"
  },
  "paths": {
    "/api/v1/cards": {
      "post": {
        "operationId": "createCard",
        "summary": "Issue a new card",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CardRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "CRD-2001",
                      "accountId": "ACC-001",
                      "type": "debit",
                      "last4": "4532",
                      "network": "Visa",
                      "status": "inactive",
                      "dailyLimit": 2000,
                      "monthlyLimit": 15000
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards/{id}": {
      "get": {
        "operationId": "getCard",
        "summary": "Get card details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "CRD-2001",
                      "accountId": "ACC-001",
                      "type": "debit",
                      "last4": "4532",
                      "network": "Visa",
                      "status": "active",
                      "dailyLimit": 2000,
                      "monthlyLimit": 15000,
                      "activatedAt": "2024-12-01T16:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards/{id}/activate": {
      "put": {
        "operationId": "activateCard",
        "summary": "Activate a card",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "id": "CRD-2001",
                      "status": "active",
                      "activatedAt": "2024-12-01T16:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards/{id}/limits": {
      "put": {
        "operationId": "updateCardLimits",
        "summary": "Update card spending limits",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dailyLimit": {
                    "type": "number"
                  },
                  "monthlyLimit": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "id": "CRD-2001",
                      "dailyLimit": 5000,
                      "monthlyLimit": 30000,
                      "updatedAt": "2024-12-01T17:00:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Card": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "debit",
              "credit",
              "virtual"
            ]
          },
          "last4": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "inactive",
              "active",
              "blocked",
              "expired"
            ]
          },
          "dailyLimit": {
            "type": "number"
          },
          "monthlyLimit": {
            "type": "number"
          }
        }
      },
      "CardRequest": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "network": {
            "type": "string"
          }
        }
      }
    }
  }
}
