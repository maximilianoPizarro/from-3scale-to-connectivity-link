{
  "openapi": "3.0.3",
  "info": {
    "title": "Account Management API",
    "version": "1.0",
    "description": "Account CRUD, balance queries, statement generation and multi-currency support"
  },
  "paths": {
    "/api/v1/accounts": {
      "get": {
        "operationId": "listAccounts",
        "summary": "List all accounts",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                },
                "examples": {
                  "default": {
                    "value": [
                      {
                        "id": "ACC-001",
                        "holder": "Maria Garcia",
                        "type": "checking",
                        "currency": "USD",
                        "balance": 15420.5,
                        "status": "active"
                      },
                      {
                        "id": "ACC-002",
                        "holder": "Carlos Lopez",
                        "type": "savings",
                        "currency": "EUR",
                        "balance": 8750.0,
                        "status": "active"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAccount",
        "summary": "Create a new account",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "ACC-003",
                      "holder": "Ana Rodriguez",
                      "type": "checking",
                      "currency": "USD",
                      "balance": 0,
                      "status": "pending"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                },
                "examples": {
                  "default": {
                    "value": {
                      "id": "ACC-001",
                      "holder": "Maria Garcia",
                      "type": "checking",
                      "currency": "USD",
                      "balance": 15420.5,
                      "status": "active"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/{id}/balance": {
      "get": {
        "operationId": "getAccountBalance",
        "summary": "Get account balance",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "examples": {
                  "default": {
                    "value": {
                      "accountId": "ACC-001",
                      "available": 15420.5,
                      "pending": 250.0,
                      "currency": "USD",
                      "lastUpdated": "2024-12-01T10:30:00Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "holder": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "checking",
              "savings",
              "investment"
            ]
          },
          "currency": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "pending",
              "closed"
            ]
          }
        }
      },
      "AccountCreate": {
        "type": "object",
        "properties": {
          "holder": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          }
        }
      }
    }
  }
}
